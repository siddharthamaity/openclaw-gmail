{
  "name": "@mcinteerj/openclaw-gmail",
  "version": "1.7.4",
  "description": "Gmail channel plugin for OpenClaw - direct Gmail API via OAuth2",
  "type": "module",
  "main": "index.ts",
  "author": "Jake McInteer <mcinteerj@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcinteerj/openclaw-gmail"
  },
  "keywords": [
    "openclaw",
    "gmail",
    "email",
    "channel",
    "plugin"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "openclaw-gmail",
      "label": "Gmail",
      "selectionLabel": "Gmail",
      "detailLabel": "Gmail",
      "docsPath": "/channels/gmail",
      "docsLabel": "gmail",
      "blurb": "Gmail integration via the direct Gmail API.",
      "systemImage": "envelope",
      "order": 100,
      "showConfigured": true
    }
  },
  "files": [
    "index.ts",
    "src/**/*.ts",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "@googleapis/gmail": "17.0.0",
    "google-auth-library": "10.9.0",
    "marked": "18.0.5",
    "nodemailer": "9.0.3",
    "proper-lockfile": "4.1.2",
    "sanitize-html": "2.17.5"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  }
}
